rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.role == "Admin";
    }

    function isOperator() {
      return signedIn() && request.auth.token.role == "Operator";
    }

    function isUser() {
      return signedIn() && request.auth.token.role == "User";
    }

    match /users/{uid} {
      allow read: if signedIn() && (isAdmin() || request.auth.uid == uid);
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if isAdmin() || (request.auth.uid == uid &&
        !('role' in request.resource.data) &&
        !('frozen' in request.resource.data));
      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if signedIn();
      allow create: if signedIn() && (isAdmin() || isOperator() || isUser());
      allow update, delete: if isAdmin();
    }

    match /road_alerts/{alertId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /operators/{operatorId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /broadcasts/{broadcastId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
  }
}